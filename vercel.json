{
  "buildCommand": "cd incident-reporting-system && npm install && npm run build",
  "outputDirectory": "incident-reporting-system/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
